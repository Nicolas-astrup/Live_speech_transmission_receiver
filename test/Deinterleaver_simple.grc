    label: Bit in
    maxoutbuf: '0'
    minoutbuf: '0'
    num_streams: '1'
    optional: 'False'
    type: byte
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [144, 276.0]
    rotation: 0
    state: enabled

connections:
- [blocks_stream_to_vector_0_0, '0', epy_block_1, '0']
