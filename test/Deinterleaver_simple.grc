- name: blocks_vector_to_stream_1_0
  id: blocks_vector_to_stream
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    num_items: '160'
    type: byte
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [704, 264.0]
    rotation: 0
    state: enabled
- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    def __init__(self, rows=8, cols=20):\n        self.rows = rows\n      \
      \  self.cols = cols\n        self.N = rows * cols\n\n        gr.sync_block.__init__(\n\
      \            self,\n            name=\"bit_deinterleaver_160\",\n          \
      \  in_sig=[(np.uint8, self.N)],\n            out_sig=[(np.uint8, self.N)]\n\
      \        )\n\n    def work(self, input_items, output_items):\n        inv =\
      \ input_items[0]\n        outv = output_items[0]\n\n        for i in range(len(inv)):\n\
      \            frame = np.array(inv[i], copy=False).reshape((self.cols, self.rows))\n\
      \            outv[i][:] = frame.T.reshape(self.N)\n\n        return len(outv)"
    affinity: ''
    alias: ''
    cols: Columns
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    rows: Rows
  states:
    _io_cache: ('bit_deinterleaver_160', 'blk', [('rows', '8'), ('cols', '20')], [('0',
      'byte', 160)], [('0', 'byte', 160)], '', ['cols', 'rows'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [464, 360.0]
    rotation: 0
    state: enabled
- name: pad_sink_0
  id: pad_sink
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    label: Bit out
    num_streams: '1'
