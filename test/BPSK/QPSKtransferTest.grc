- name: epy_block_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nimport pmt\nfrom gnuradio import gr\n\nclass\
      \ blk(gr.sync_block):\n    def __init__(self, packet_len=160, cols=16):\n  \
      \      gr.sync_block.__init__(\n            self,\n            name='Deinterleaver',\n\
      \            in_sig=[np.uint8],\n            out_sig=[np.uint8]\n        )\n\
      \        self.packet_len = packet_len\n        self.cols = cols\n        self.rows\
      \ = packet_len // cols\n        self.buffer = []\n        self.copying = False\n\
      \        self.remaining = 0\n        self.set_tag_propagation_policy(gr.TPP_DONT)\n\
      \n    def work(self, input_items, output_items):\n        in0 = input_items[0]\n\
      \        out = output_items[0]\n        n_produced = 0\n\n        tags = self.get_tags_in_window(0,\
      \ 0, len(in0))\n        for tag in tags:\n            if pmt.to_python(tag.key)\
      \ == 'packet_len':\n                self.copying = True\n                self.remaining\
      \ = pmt.to_python(tag.value)\n                self.buffer = []\n\n        for\
      \ i, byte in enumerate(in0):\n            if self.copying and self.remaining\
      \ > 0:\n                self.buffer.append(byte)\n                self.remaining\
      \ -= 1\n\n                if self.remaining == 0:\n                    packet\
      \ = np.array(self.buffer, dtype=np.uint8)\n                    matrix = packet.reshape(self.cols,\
      \ self.rows)\n                    deinterleaved = matrix.T.flatten()\n\n   \
      \                 out[n_produced:n_produced + self.packet_len] = deinterleaved\n\
      \n                    self.add_item_tag(\n                        0,\n     \
      \                   self.nitems_written(0) + n_produced,\n                 \
      \       pmt.intern('packet_len'),\n                        pmt.from_long(self.packet_len)\n\
      \                    )\n\n                    n_produced += self.packet_len\n\
      \                    self.copying = False\n                    self.buffer =\
      \ []\n\n        return n_produced"
    affinity: ''
    alias: ''
    cols: '8'
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    packet_len: '160'
  states:
    _io_cache: ('Deinterleaver', 'blk', [('packet_len', '160'), ('cols', '16')], [('0',
      'byte', 1)], [('0', 'byte', 1)], '', ['cols', 'packet_len'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [248, 1464.0]
    rotation: 0
    state: disabled
- name: epy_block_0_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    def __init__(self, packet_size=6):\n        gr.sync_block.__init__(\n \
      \           self,\n            name=\"RX Byte Counter\",\n            in_sig=[np.uint8],\n\
      \            out_sig=[np.float32]\n        )\n\n        self.total_bytes = 0\n\
      \        self.packet_size = packet_size\n\n    def work(self, input_items, output_items):\n\
      \        n = len(input_items[0])\n        out = output_items[0]\n\n        self.total_bytes\
      \ += n\n\n        # choose one:\n        value = self.total_bytes   / 6    \
      \        # bytes\n        # value = self.total_bytes / self.packet_size   #\
      \ packets\n\n        out[:] = float(value)\n\n        return n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    packet_size: '6'
  states:
    _io_cache: ('RX Byte Counter', 'blk', [('packet_size', '6')], [('0', 'byte', 1)],
      [('0', 'float', 1)], '', ['packet_size'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1032, 1800.0]
    rotation: 0
    state: disabled
- name: epy_block_0_0_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    def __init__(self, packet_size=6):\n        gr.sync_block.__init__(\n \
      \           self,\n            name=\"RX Byte Counter\",\n            in_sig=[np.uint8],\n\
      \            out_sig=[np.float32]\n        )\n\n        self.total_bytes = 0\n\
      \        self.packet_size = packet_size\n\n    def work(self, input_items, output_items):\n\
      \        n = len(input_items[0])\n        out = output_items[0]\n\n        self.total_bytes\
      \ += n\n\n        # choose one:\n        value = self.total_bytes   / 6    \
      \        # bytes\n        # value = self.total_bytes / self.packet_size   #\
      \ packets\n\n        out[:] = float(value)\n\n        return n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    packet_size: '10'
  states:
    _io_cache: ('RX Byte Counter', 'blk', [('packet_size', '6')], [('0', 'byte', 1)],
      [('0', 'float', 1)], '', ['packet_size'])
