- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass blk(gr.sync_block):\n\
      \    def __init__(self, window_bytes=600):\n        gr.sync_block.__init__(\n\
      \            self,\n            name=\"PER Window Bytes (FEC in0, CRC in1)\"\
      ,\n            in_sig=[np.float32, np.float32],\n            out_sig=[np.float32]\n\
      \        )\n\n        self.window_bytes = int(window_bytes)\n\n        self.prev_fec_bytes\
      \ = 0\n        self.prev_crc_bytes = 0\n\n        self.win_fec_bytes = 0\n \
      \       self.win_crc_bytes = 0\n\n        self.per = 0.0\n\n    def work(self,\
      \ input_items, output_items):\n        fec_now = int(input_items[0][-1])   #\
      \ input 0 = FEC bytes\n        crc_now = int(input_items[1][-1])   # input 1\
      \ = CRC good bytes\n        out = output_items[0]\n\n        dfec = fec_now\
      \ - self.prev_fec_bytes\n        dcrc = crc_now - self.prev_crc_bytes\n\n  \
      \      self.prev_fec_bytes = fec_now\n        self.prev_crc_bytes = crc_now\n\
      \n        if dfec < 0: dfec = 0\n        if dcrc < 0: dcrc = 0\n\n        self.win_fec_bytes\
      \ += dfec\n        self.win_crc_bytes += dcrc\n\n        if self.win_fec_bytes\
      \ >= self.window_bytes:\n            failed = self.win_fec_bytes - self.win_crc_bytes\n\
      \            if failed < 0:\n                failed = 0\n\n            self.per\
      \ = failed / float(self.win_fec_bytes)\n\n            self.win_fec_bytes = 0\n\
      \            self.win_crc_bytes = 0\n\n        out[:] = self.per\n        return\
      \ len(out)"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    window_bytes: '100'
  states:
    _io_cache: ('PER Window Bytes (FEC in0, CRC in1)', 'blk', [('window_bytes', '600')],
      [('0', 'float', 1), ('1', 'float', 1)], [('0', 'float', 1)], '', ['window_bytes'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1224, 1960.0]
    rotation: 0
    state: disabled
